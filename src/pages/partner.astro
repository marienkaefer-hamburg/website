---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Partner" description="Unsere Partner: Freie und Hansestadt Hamburg, SOAL Alternativer Wohlfahrtsverband e.V. und weitere.">
  <section class="page-head">
    <div class="container">
      <p class="breadcrumb"><a href="/">Start</a> · Partner</p>
      <h1>Unsere Partner</h1>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="cards">
        <div class="card"><div class="card__body">
          <h3>Freie und Hansestadt Hamburg</h3>
          <p>Behörde für Soziales und Familie<br /><a href="https://www.kita.hamburg.de/" target="_blank" rel="noopener">www.kita.hamburg.de</a></p>
        </div></div>
        <div class="card"><div class="card__body">
          <h3>SOAL e.V.</h3>
          <p>Alternativer Wohlfahrtsverband und Dachverband<br /><a href="https://www.soal.de/" target="_blank" rel="noopener">www.soal.de</a></p>
        </div></div>
        <div class="card"><div class="card__body">
          <h3>Gastronomie „Bumblebee"</h3>
          <p>Christiane Beck – unsere Partnerin rund ums Essen.</p>
        </div></div>
      </div>
    </div>
  </section>
</BaseLayout>
