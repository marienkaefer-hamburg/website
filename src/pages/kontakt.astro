---
import BaseLayout from '../layouts/BaseLayout.astro';
import { site } from '../data/site';
---
<BaseLayout title="Kontakt" description="Kontakt und Anmeldung beim Kindergarten Marienkäfer: Zikadenweg 18, 22043 Hamburg. Telefon 040 – 68 41 51.">
  <section class="page-head">
    <div class="container">
      <p class="breadcrumb"><a href="/">Start</a> · Kontakt</p>
      <h1>Kontakt</h1>
      <p>Sie erreichen uns {site.hours.toLowerCase()}.</p>
    </div>
  </section>

  <section class="section">
    <div class="container contact-grid">
      <div class="contact-card">
        <h3>So erreichen Sie uns</h3>
        <ul class="contact-list">
          <li><strong>{site.legalName}</strong></li>
          <li>{site.address.street}<br />{site.address.zip} {site.address.city}</li>
          <li>Telefon: <a href={`tel:${site.phoneHref}`}>{site.phone}</a></li>
          <li>E-Mail: <a href={`mailto:${site.email}`}>{site.email}</a></li>
          <li>{site.hours}<br /><span style="color:var(--muted)">{site.coreHours}</span></li>
        </ul>
      </div>
      <div class="contact-card">
        <h3>Leitung &amp; Vorstand</h3>
        <ul class="contact-list">
          <li><strong>Pädagogische Leitung</strong><br />Kristin „Tine" Schüning</li>
          <li><strong>Stellvertretende Leitung</strong><br />Freia Cieslik</li>
          <li><strong>Vorstand</strong><br />1. Vorstand: Lale Fröhlich-Heidemann<br />2. Vorstand: Lukas Zerck</li>
        </ul>
      </div>
    </div>
  </section>

  <section class="section section--sand" id="anmeldung">
    <div class="container">
      <div class="callout" style="max-width:820px;margin-inline:auto;">
        <h2 style="margin-top:0;">Platz anfragen &amp; Anmeldung</h2>
        <p>Sie möchten Ihr Kind bei uns anmelden? Wir freuen uns über Ihr Interesse! Rufen Sie uns einfach an oder schreiben Sie uns eine E-Mail – wir empfehlen, frühzeitig Kontakt aufzunehmen und Ihr Kind auf unsere Warteliste setzen zu lassen.</p>
        <p>Wir beteiligen uns am Hamburger Kita-Gutschein-System. Ein Gutschein garantiert die Übernahme des staatlichen Anteils der Betreuungskosten und ist beim Jugendamt Ihres Bezirks zu beantragen.</p>
        <div class="hero__cta" style="margin-top:1rem;">
          <a class="btn" href={`mailto:${site.email}?subject=Anfrage%20Betreuungsplatz`}>E-Mail schreiben</a>
          <a class="btn btn--ghost" href={`tel:${site.phoneHref}`}>{site.phone}</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
