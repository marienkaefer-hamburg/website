---
import { site, nav } from '../data/site';
const year = new Date().getFullYear();
---
<footer class="site-footer">
  <div class="container">
    <div class="footer-grid">
      <div>
        <h4>{site.legalName}</h4>
        <p>
          {site.address.street}<br />
          {site.address.zip} {site.address.city}<br />
          Tel.: <a href={`tel:${site.phoneHref}`}>{site.phone}</a><br />
          <a href={`mailto:${site.email}`}>{site.email}</a>
        </p>
        <p>{site.hours}</p>
      </div>
      <div>
        <h4>Seiten</h4>
        <ul>
          {nav.map((item) => <li><a href={item.href}>{item.label}</a></li>)}
          <li><a href="/partner/">Partner</a></li>
        </ul>
      </div>
      <div>
        <h4>Rechtliches</h4>
        <ul>
          <li><a href="/impressum/">Impressum</a></li>
          <li><a href="/datenschutz/">Datenschutz</a></li>
        </ul>
      </div>
    </div>
    <div class="footer-bottom">
      <span>© {year} {site.legalName}</span>
      <span>Eine Elterninitiative seit 1994.</span>
    </div>
  </div>
</footer>
